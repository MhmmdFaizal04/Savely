---
const steps = [
  {
    number: '01',
    title: 'Copy the link',
    body: 'Open the video on Instagram, TikTok, YouTube, or Facebook and copy its URL from the address bar or share menu.',
  },
  {
    number: '02',
    title: 'Paste into Savely',
    body: 'Head to the Download page, paste the link into the input field, and hit Enter. Savely detects the platform automatically.',
  },
  {
    number: '03',
    title: 'Save to your device',
    body: 'Your direct download link is ready. Click to save the video straight to your device — no apps, no sign-up required.',
  },
];
---
<section class="how" id="how">
  <div class="container">
    <div class="how-header">
      <span class="section-label">How it works</span>
      <h2 class="section-title">Three steps to save</h2>
    </div>
    <ol class="steps-list">
      {steps.map(({ number, title, body }) => (
        <li class="step-card card">
          <span class="step-number">{number}</span>
          <div class="step-line-wrap" aria-hidden="true">
            <div class="step-line"></div>
          </div>
          <h3 class="step-title">{title}</h3>
          <p class="step-body">{body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how {
    padding-block: 6rem;
  }

  .how-header {
    margin-bottom: 3.5rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-orange);
    display: block;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-body);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .steps-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    counter-reset: steps;
  }

  .step-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s;
  }
  .step-card:hover { border-color: rgba(255, 140, 66, 0.35); }

  .step-number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-orange);
    letter-spacing: 0.08em;
  }

  .step-line-wrap {
    width: 100%;
    height: 1px;
    background: var(--color-border);
    overflow: hidden;
  }

  .step-line {
    width: 0%;
    height: 100%;
    background: var(--color-orange);
    opacity: 0.5;
  }

  .step-title {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .step-body {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.65;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Cards fade up
  gsap.set('.step-card', { opacity: 0, y: 28 });
  gsap.to('.step-card', {
    opacity: 1,
    y: 0,
    duration: 0.7,
    stagger: 0.18,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '.steps-list',
      start: 'top 78%',
    },
  });

  // Accent line draw per card
  gsap.utils.toArray<HTMLElement>('.step-line').forEach((line) => {
    gsap.to(line, {
      width: '100%',
      duration: 1.2,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: line,
        start: 'top 82%',
      },
    });
  });
</script>
